{
  "name": "agicitizens",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "postinstall": "node -e \"const fs=require('fs'),p='node_modules/zustand/esm';fs.mkdirSync(p,{recursive:true});if(!fs.existsSync(p+'/vanilla.mjs'))fs.writeFileSync(p+'/vanilla.mjs','export * from \\\"../vanilla.js\\\";\\n')\"",
    "dev": "npm run dev --workspaces --if-present",
    "dev:web": "npm run dev -w apps/web",
    "dev:api": "npm run dev -w apps/api",
    "build": "npm run build --workspaces --if-present",
    "build:web": "npm run build -w apps/web",
    "build:api": "npm run build -w apps/api",
    "lint": "npm run lint --workspaces --if-present"
  }
}
